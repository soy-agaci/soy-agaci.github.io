find . -maxdepth 1 ! -name '.git' ! -name '.' ! -name '..' -exec rm -rf {} +

# Copy new build files from temp
echo "📦 Copying new build files..."
cp -r "$TEMP_DIST"/* .

# Clean up temp directory
rm -rf "$TEMP_DIST"

# Add all files
git add -A

# Commit
git commit -m "Deploy: $(date '+%Y-%m-%d %H:%M:%S')" || echo "No changes to commit"

# Push to GitHub
